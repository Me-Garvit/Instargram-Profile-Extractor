    {
      "parameters": {
        "jsCode": "const output = [];\n\nconst POST_REEL_PATTERNS = ['/p/', '/reel/'];\nconst BLOCKED_PATTERNS = ['/explore/', '/stories/', '/tv/', '/highlights/'];\nconst INSTAGRAM_DOMAINS = ['instagram.com', 'www.instagram.com'];\n\nfunction isInstagramPostOrReel(url) {\n  try {\n    const { hostname, pathname } = new URL(url);\n\n    // Must be an Instagram domain\n    if (!INSTAGRAM_DOMAINS.includes(hostname)) return false;\n\n    const cleanPath = pathname.replace(/\\/+$/, ''); // strip trailing slash\n    const segments = cleanPath.split('/').filter(Boolean); // ['dremwedgeworth'] or ['p', 'ABC123']\n\n    // Block explicit bad patterns\n    if (BLOCKED_PATTERNS.some(p => pathname.includes(p))) return false;\n\n    // Profile URLs: instagram.com/username or instagram.com/username/\n    // These have exactly 1 path segment\n    if (segments.length === 1) return false;\n\n    // Must contain a post or reel path segment\n    return POST_REEL_PATTERNS.some(p => pathname.includes(p));\n\n  } catch {\n    return false;\n  }\n}\n\nfor (const item of $input.all()) {\n  const results = item.json.organic || [];\n  for (const result of results) {\n    if (!result.link || !isInstagramPostOrReel(result.link)) continue;\n    output.push({\n      json: {\n        url: result.link,\n        name: result.title,\n        snippet: result.snippet,\n        type: result.link.includes('/reel/') ? 'reel' : 'post'\n      }\n    });\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -928,
        800
      ],
      "id": "1ff89709-bfe2-4d3e-a109-834c21045eae",
      "name": "URL Node"
    },
    {
      "parameters": {
        "jsCode": "const queries = [\n  // 🧠 CORE: DOCTOR + CREATOR + MONETIZATION\n  `site:instagram.com (\"Dr.\" OR \"MD\" OR \"physician\") (\"online coach\" OR \"coach\" OR \"program\") (\"DM\" OR \"apply\" OR \"link in bio\") (USA OR UK) -hospital -clinic -center -india -indian -job`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"helping\" OR \"I help\") (\"clients\" OR \"patients\") (\"program\" OR \"coaching\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"doctor\" OR \"physician\") (\"online program\" OR \"coaching\") (\"results\" OR \"clients\") (USA OR UK) -hospital -clinic -india -indian`,\n\n  // 💰 INBOUND LEAD SIGNALS (VERY IMPORTANT)\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"DM me\" OR \"message me\") (\"program\" OR \"help you\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"apply now\" OR \"apply below\") (\"program\" OR \"coaching\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"link in bio\") (\"program\" OR \"consult\") (USA OR UK) -hospital -clinic -india -indian`,\n\n  // 🧬 NICHE: HIGH-TICKET HEALTH CREATOR SEGMENTS\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"functional medicine\" OR \"holistic health\") (\"program\" OR \"clients\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"gut health\" OR \"hormone health\") (\"program\" OR \"coaching\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"weight loss\" OR \"fat loss\") (\"program\" OR \"clients\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"pcos\" OR \"thyroid\" OR \"diabetes\") (\"program\" OR \"helping\") (USA OR UK) -hospital -clinic -india -indian`,\n\n  // 🧠 AUTHORITY + PERSONAL BRAND LANGUAGE\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"educating\" OR \"tips\" OR \"content\") (\"program\" OR \"coaching\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"creator\" OR \"educator\") (\"clients\" OR \"program\") (USA OR UK) -hospital -clinic -india -indian`,\n\n  // 🔥 TRANSFORMATION / SOCIAL PROOF (BEST LEADS)\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"client results\" OR \"transformation\") (\"program\" OR \"coaching\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"helped\" OR \"worked with\") (\"clients\" OR \"patients\") (\"program\") (USA OR UK) -hospital -clinic -india -indian`,\n\n  // 🎯 CONSULT-BASED MONETIZATION\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"consultation\" OR \"consult\") (\"book\" OR \"link in bio\") (USA OR UK) -hospital -clinic -india -indian`,\n  `site:instagram.com (\"Dr.\" OR \"MD\") (\"telehealth\" OR \"virtual consult\") (\"book\" OR \"patients\") (USA OR UK) -hospital -clinic -india -indian`\n];\n\nconst output = [];\nfor (const q of queries) {\n  for (let start = 0; start < 50; start += 10) {\n    output.push({ json: { q, start } });\n  }\n}\nreturn output;"
      },
