    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const username = item.json.user_posted;\n  const fullName = item.json.owner_full_name || username;\n\n  return {\n    json: {\n      username: username,\n      profile_name: fullName,\n      profile_url: `https://www.instagram.com/${username}/`\n    }\n  };\n});"
      },
