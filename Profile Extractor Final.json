    {
      "parameters": {
        "jsCode": "const output = [];\nconst seen = new Set(); // 🔥 tracks unique URLs\n\nfor (const item of $input.all()) {\n  const url = item.json.URL;\n\n  if (!url) continue;\n\n  // Normalize URL (important for dedup)\n  const cleanUrl = url.split('?')[0].replace(/\\/+$/, '');\n\n  if (\n    cleanUrl.includes('instagram.com/reel/') ||\n    cleanUrl.includes('instagram.com/p/')\n  ) {\n    // ❌ Skip if already seen\n    if (seen.has(cleanUrl)) continue;\n\n    // ✅ Mark as seen\n    seen.add(cleanUrl);\n\n    output.push({\n      json: {\n        url: cleanUrl,\n        name: item.json.Name || '',\n        snippet: item.json.Snippet || '',\n        type: cleanUrl.includes('/reel/') ? 'reel' : 'post'\n      }\n    });\n  }\n}\n\nreturn output;"
      },
