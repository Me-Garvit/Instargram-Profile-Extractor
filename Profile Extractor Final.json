    {
      "parameters": {
        "jsCode": "// NODE 1: MAIN PROFILES\nreturn items.map(item => {\n  const d = item.json;\n\n  // Collect all unique URLs from both the primary field and the array\n  let urlList = [];\n  if (d.externalUrls && Array.isArray(d.externalUrls)) {\n    urlList = d.externalUrls.map(u => u.url).filter(Boolean);\n  }\n  if (d.externalUrl && !urlList.includes(d.externalUrl)) {\n    urlList.unshift(d.externalUrl);\n  }\n\n  return {\n    json: {\n      username: d.username,\n      fullName: d.fullName,\n      biography: d.biography,\n      category: d.businessCategoryName,\n      external_urls: urlList.join(', '), // Stores all links in one cell\n      followers: d.followersCount,\n      posts_count: d.postsCount,\n      profile_link: d.url,\n      is_business: d.isBusinessAccount,\n      is_verified: d.isVerified\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        624
      ],
      "id": "ab8da15d-6ebd-474d-bb8c-73d555ce6d19",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "// NODE 2: RELATED PROFILES (EXPANSION)\nconst expansionData = [];\n\nfor (const item of items) {\n  const parent = item.json.username;\n  const related = item.json.relatedProfiles || [];\n\n  for (const profile of related) {\n    expansionData.push({\n      json: {\n        found_via_parent: parent,\n        username: profile.username,\n        fullName: profile.fullName,\n        profile_link: `https://www.instagram.com/${profile.username}`\n      }\n    });\n  }\n}\n\nreturn expansionData;"
      },
